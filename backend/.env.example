CEREBRUM_API_URL=http://localhost:8000
CEREBRUM_API_KEY=cb_dev_key

# LLM provider: Qwen (DashScope) OR Ollama (local/remote)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

OLLAMA_URL=
OLLAMA_MODEL=gpt-oss:120b-cloud

STORAGE_PATH=./storage
CHROMA_PERSIST_DIR=./storage/chroma

# Fine-tuning (Cloudflare Workers AI) -- optional
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
FINE_TUNE_BASE_MODEL=gpt-oss:120b-cloud

# Dataset upload fallback / auto-deploy Git auth
GITHUB_TOKEN=
GITHUB_USERNAME=bopoadz-del
DEPLOY_REPO=https://github.com/bopoadz-del/CerebrumDev.ai

# Optional R2 dataset upload
R2_BUCKET_NAME=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
